# Required
LLM_API_KEY=your-api-key-here

# Optional — LLM configuration
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_MODEL=

# Optional — GitHub token for README fallback and git push
GH_TOKEN=your-github-pat-here

# Optional — paths and concurrency
OUTPUT_DIR=./output
STATE_FILE=./state/reviewed.json
FETCH_CONCURRENCY=3
LLM_CONCURRENCY=3

# Optional — daemon mode
CRON_SCHEDULE=0 */6 * * *

# Optional — git repo for pushing output
GIT_REPO_URL=https://github.com/yourname/pi-package-index.git
GIT_REPO_DIR=/repo
